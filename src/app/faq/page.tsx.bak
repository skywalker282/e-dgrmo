'use client'

import React, { useState } from 'react'

export default function FAQPage() {
  const [openIndex, setOpenIndex] = useState<number | null>(null)

  const toggleFAQ = (index: number) => {
    setOpenIndex(openIndex === index ? null : index)
  }

  const faqCategories = [
    {
      title: 'Questions générales',
      faqs: [
        {
          question: "Qu'est-ce que le portail E-DGRMO ?",
          answer: 'Le portail E-DGRMO est la plateforme en ligne officielle de la Direction Générale des Recettes de la Mongala. Il permet aux contribuables de payer leurs taxes, vérifier leurs reçus, déposer des plaintes et accéder à divers services fiscaux en ligne.'
        },
        {
          question: 'Comment puis-je créer un compte ?',
          answer: 'Pour créer un compte, cliquez sur le bouton "S\'inscrire" en haut à droite du site. Vous devrez fournir vos informations personnelles et choisir un mot de passe sécurisé. Pour les entreprises, des documents supplémentaires seront requis.'
        },
        {
          question: 'Est-ce que le site est sécurisé ?',
          answer: 'Oui, notre site utilise des protocoles de sécurité avancés, y compris le cryptage SSL, l\'authentification à deux facteurs et des mesures de protection contre la fraude pour garantir la sécurité de vos informations et transactions.'
        }
      ]
    },
    {
      title: 'Paiements et taxes',
      faqs: [
        {
          question: 'Comment puis-je payer mes taxes en ligne ?',
          answer: 'Connectez-vous à votre compte, sélectionnez la taxe concernée, calculez le montant à payer à l\'aide de notre calculateur, puis choisissez votre méthode de paiement (mobile money, carte bancaire ou virement bancaire).'
        },
        {
          question: 'Quels modes de paiement sont acceptés ?',
          answer: 'Nous acceptons les paiements par mobile money (MPesa, Airtel Money), les cartes bancaires (Visa, Mastercard), et les virements bancaires. Tous les paiements sont traités de manière sécurisée.'
        },
        {
          question: 'Combien de temps pour recevoir un reçu après le paiement ?',
          answer: 'Les reçus électroniques sont générés immédiatement après le paiement réussi. Vous pouvez les télécharger au format PDF ou les imprimer directement depuis votre tableau de bord.'
        },
        {
          question: 'Puis-je payer plusieurs taxes en une seule transaction ?',
          answer: 'Actuellement, chaque transaction est limitée à une seule taxe. Cependant, vous pouvez effectuer plusieurs paiements successifs dans la même session.'
        }
      ]
    },
    {
      title: 'Reçus et vérification',
      faqs: [
        {
          question: 'Comment vérifier l\'authenticité d\'un reçu de paiement ?',
          answer: 'Vous pouvez scanner le code QR sur le reçu avec votre téléphone ou entrer le numéro du reçu dans la section "Vérification de reçu" de notre site pour confirmer son authenticité.'
        },
        {
          question: 'Que faire si je perds mon reçu ?',
          answer: 'Connectez-vous à votre compte et accédez à la section "Historique des paiements". Vous pouvez télécharger à nouveau n\'importe quel reçu électronique précédemment généré.'
        },
        {
          question: 'Combien de temps les reçus sont-ils conservés ?',
          answer: 'Tous les reçus électroniques sont conservés pendant 7 ans conformément aux exigences légales. Vous pouvez les télécharger à tout moment depuis votre tableau de bord.'
        }
      ]
    },
    {
      title: 'Plaintes et assistance',
      faqs: [
        {
          question: 'Comment déposer une plainte ?',
          answer: 'Connectez-vous à votre compte et accédez à la section "Dépôt de plainte". Remplissez le formulaire en décrivant votre problème et joignez tous les documents pertinents. Vous recevrez un numéro de référence pour suivre votre plainte.'
        },
        {
          question: 'Combien de temps pour recevoir une réponse à une plainte ?',
          answer: 'Nous nous engageons à répondre à toutes les plaintes dans un délai de 5 jours ouvrables. Vous pouvez suivre l\'état d\'avancement de votre plainte via votre tableau de bord.'
        },
        {
          question: 'Comment contacter le service client ?',
          answer: 'Vous pouvez nous contacter par téléphone au +243 123 456 789, par email à support@dgrmo.cd, ou via le formulaire de contact sur notre site. Notre service client est disponible du lundi au vendredi de 8h à 17h.'
        }
      ]
    }
  ]
}

  return (
    <div className="min-h-screen">
      <div className="bg-dark-navy text-white py-20">
        <div className="container mx-auto px-4">
          <div className="max-w-4xl mx-auto text-center">
            <h1 className="text-4xl md:text-5xl font-bold mb-6">
              Questions fréquemment posées
            </h1>
            <p className="text-xl text-gray-300">
              Trouvez des réponses aux questions les plus courantes
            </p>
          </div>
        </div>
      </div>

      <div className="py-16">
        <div className="container mx-auto px-4">
          <div className="max-w-6xl mx-auto">
            <div className="mb-12">
              <div className="relative max-w-2xl mx-auto">
                <input
                  type="text"
                  placeholder="Rechercher dans les questions..."
                  className="w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:ring-2 focus:ring-primary-blue pl-10"
                />
                <span className="absolute left-3 top-3.5 text-gray-400">🔍</span>
              </div>
            </div>

            <div className="space-y-16">
              {faqCategories.map((category, categoryIndex) => (
                <div key={categoryIndex}>
                  <h2 className="text-3xl font-bold mb-8 text-center">{category.title}</h2>
                  <div className="space-y-4">
                    {category.faqs.map((faq, faqIndex) => {
                      const globalIndex = categoryIndex * 100 + faqIndex
                      return (
                        <div key={faqIndex} className="border border-gray-200 rounded-sm">
                          <button
                            className="w-full text-left p-6 bg-white flex justify-between items-center"
                            onClick={() => toggleFAQ(globalIndex)}
                          >
                            <span className="font-semibold text-lg">{faq.question}</span>
                            <span className="text-primary-blue text-2xl">
                              {openIndex === globalIndex ? '−' : '+'}
                            </span>
                          </button>
                          {openIndex === globalIndex && (
                            <div className="p-6 bg-white border-t border-gray-200">
                              <p className="text-gray">{faq.answer}</p>
                            </div>
                          )}
                        </div>
                      )
                    })}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

            <div className="mt-16 bg-light-blue rounded-sm p-8 text-center">
              <h2 className="text-2xl font-bold mb-4">Vous ne trouvez pas la réponse à votre question ?</h2>
              <p className="text-gray mb-6">
                Notre équipe de support est prête à vous aider
              </p>
              <div className="flex flex-col sm:flex-row justify-center gap-4">
                <button className="bg-primary-blue hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-sm">
                  Contacter le support
                </button>
                <button className="border border-primary-blue text-primary-blue hover:bg-blue-50 font-semibold py-3 px-6 rounded-sm">
                  Déposer une plainte
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}